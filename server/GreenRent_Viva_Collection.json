{
    "info": {
        "_postman_id": "viva-final-v3",
        "name": "GreenRent - Final Viva Demo (User & Recommendations)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. User Management",
            "item": [
                {
                    "name": "Register User (Avatars)",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Jane Viva\",\n    \"email\": \"jane.viva@example.com\",\n    \"password\": \"SecurePass123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"jane.viva@example.com\",\n    \"password\": \"SecurePass123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Profile Data (Show Avatar)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/user/data",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "user",
                                "data"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. Smart Recommendations (Unique Factor)",
            "item": [
                {
                    "name": "Get Recommendations (Walkability Score)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/recommendations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "recommendations"
                            ]
                        },
                        "description": "Show how the mobility/walkability factor influences the smart score calculation."
                    },
                    "response": []
                },
                {
                    "name": "Update Preferences (Change Weighting)",
                    "request": {
                        "method": "PUT",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"ecoPriority\": \"high\",\n    \"budgetMin\": 0,\n    \"budgetMax\": 5000\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/recommendations/preferences",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "recommendations",
                                "preferences"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "3. 3rd Party API Independent Demo",
            "item": [
                {
                    "name": "Fetch Mobility Data (OSM Standalone)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/recommendations/mobility-check?lat=6.9271&lon=79.8612",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "recommendations",
                                "mobility-check"
                            ],
                            "query": [
                                {
                                    "key": "lat",
                                    "value": "6.9271"
                                },
                                {
                                    "key": "lon",
                                    "value": "79.8612"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "token",
            "value": "PASTE_TOKEN_HERE",
            "type": "string"
        }
    ]
}