        {
            "name": "3. 3rd Party API Independent Check",
            "item": [
                {
                    "name": "Mobility Check (OSM Standalone)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/recommendations/mobility-check?lat=6.9271&lon=79.8612",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "recommendations",
                                "mobility-check"
