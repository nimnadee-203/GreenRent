                                    "key": "lat",
                                    "value": "6.9271"
                                },
                                {
                                    "key": "lon",
                                    "value": "79.8612"
                                }
                            ]
                        },
                        "description": "Prove you can fetch live transit and amenity data for any location. (Example: Colombo)"
